# Server
PORT=3000

# Database
POSTGRES_USER=turtle
POSTGRES_PASSWORD=turtle123
POSTGRES_DB=turtle_soup

# JWT
JWT_SECRET=change_me_in_production_use_random_64_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_use_random_64_chars

# CORS (comma-separated origins; leave empty for wildcard in dev)
CORS_ORIGIN=http://localhost:5173

# Initial invite code (created on first run)
INITIAL_INVITE_CODE=TURTLE2024

# AI 配置 - 全部留空则禁用 AI 功能
# AI_PROVIDER: 提供商名称（自定义，如 deepseek、openai、custom）
# AI_BASE_URL: API 基础地址（OpenAI 兼容格式）
# AI_API_KEY: API 密钥
# AI_MODEL: 模型名称（如 deepseek-chat、gpt-4o、glm-5）
# AI_REQUEST_TIMEOUT: 请求超时时间（毫秒），建议 30000-60000
AI_PROVIDER=
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_REQUEST_TIMEOUT=30000
